# Production .env – copy to server as .env and fill values
# Do NOT use this file locally; keep NODE_ENV=development for local dev

NODE_ENV=production
PORT=5001

# MongoDB (production only)
MONGODB_URI=mongodb://user:pass@host/sgc_erp?retryWrites=true&w=majority

# Auth
JWT_SECRET=your-secure-jwt-secret-min-32-chars
JWT_EXPIRE=24h

# URLs (tovus.net already in CORS; add others comma-separated)
CORS_ORIGIN=
FRONTEND_URL=https://tovus.net
# API base URL for public links (e.g. WhatsApp media) – Meta must be able to fetch from this URL
API_BASE_URL=https://api.tovus.net

# Email (SMTP)
SMTP_HOST=mail.sgc.international
SMTP_PORT=465
SMTP_USER=hr@sgc.international
SMTP_PASS=your-smtp-password

# WhatsApp Cloud API (Meta)
WHATSAPP_ACCESS_TOKEN=your-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=962045766999656
WHATSAPP_WEBHOOK_VERIFY_TOKEN=sgc_whatsapp_verify_2025

# Rate limiting (optional overrides)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=200
# LOGIN_RATE_LIMIT_MAX=20

# ZKTeco (if using hardware)
# ZKTECO_HOST=45.115.86.139
# ZKTECO_PORT=85
