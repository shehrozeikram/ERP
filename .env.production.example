# Production .env – copy to server as .env and fill values
# Do NOT use this file locally; keep NODE_ENV=development for local dev

NODE_ENV=production
PORT=5001

# MongoDB (production) — database runs on the same droplet as the app (not Atlas).
# deploy-simple.sh uploads this file as .env on the server. Use localhost from Node’s view on the droplet:
# MONGODB_URI=mongodb://admin:ENCODED_PASSWORD@127.0.0.1:27017/sgc_erp?authSource=admin
# Build the line on the server: scripts/print-droplet-mongodb-uri.sh (see scripts/mongorestore-on-droplet.sh).
# Placeholder only (replace with real URI before deploy):
MONGODB_URI=mongodb://admin:ENCODED_PASSWORD@127.0.0.1:27017/sgc_erp?authSource=admin
# Do not set MONGODB_URI_LOCAL on the server (local dev only, on your Mac).

# Auth
JWT_SECRET=your-secure-jwt-secret-min-32-chars
JWT_EXPIRE=24h

# URLs (tovus.net already in CORS; add others comma-separated)
CORS_ORIGIN=
FRONTEND_URL=https://tovus.net
# API base URL for public links (e.g. WhatsApp media) – Meta must be able to fetch from this URL
API_BASE_URL=https://api.tovus.net

# Email (SMTP)
SMTP_HOST=mail.sgc.international
SMTP_PORT=465
SMTP_USER=hr@sgc.international
SMTP_PASS=your-smtp-password

# WhatsApp Cloud API (Meta)
WHATSAPP_ACCESS_TOKEN=your-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=962045766999656
WHATSAPP_WEBHOOK_VERIFY_TOKEN=sgc_whatsapp_verify_2025

# Rate limiting (optional overrides; per public IP — NAT offices need higher limits)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=2500
# LOGIN_RATE_LIMIT_MAX=20

# ZKTeco (if using hardware)
# ZKTECO_HOST=45.115.86.139
# ZKTECO_PORT=85
