# Local development .env – copy to .env and adjust

NODE_ENV=development
PORT=5001

# MongoDB (local or cloud)
MONGODB_URI=mongodb://localhost:27017/sgc_erp
# Optional: use separate local DB so production DB stays untouched
# MONGODB_URI_LOCAL=mongodb://localhost:27017/sgc_erp_local

# Auth
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRE=24h
# How long after access-token expiry POST /auth/refresh-token may still renew (seconds). Default 7 days.
JWT_REFRESH_GRACE_SECONDS=604800

# URLs (for email links, QR codes, etc.)
FRONTEND_URL=http://localhost:3000

# Email (optional for local)
SMTP_HOST=mail.sgc.international
SMTP_PORT=465
SMTP_USER=hr@sgc.international
SMTP_PASS=

# WhatsApp (optional for local; use Meta test token if needed)
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=sgc_whatsapp_verify_2025

# Demo seed: npm run demo:seed-full-advance-pending-finance
# E2E_API_URL=http://localhost:5001/api
# E2E_EMAIL=ceo@sgc.com
# E2E_PASSWORD=
# Single-user local demo only (server must use NODE_ENV≠production; restart after change):
# E2E_BYPASS_INDENT_APPROVAL=true
# Or use a second HoD user instead of bypass:
# E2E_INDENT_APPROVER_EMAIL=
# E2E_INDENT_APPROVER_PASSWORD=
# Vendor for demo:seed-full-advance-pending-finance (must exist in DB; default AJAB KHAN BROTHERS)
# E2E_SEED_VENDOR_NAME=AJAB KHAN BROTHERS
