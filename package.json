{
  "name": "erp-system",
  "version": "1.0.0",
  "description": "Enterprise Resource Planning System with HR, Finance, Procurement, Sales, and CRM modules",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && CI=false npm run build",
    "install-all": "npm install && cd client && npm install",
    "start": "node server/index.js",
    "start:prod": "NODE_ENV=production node server/index.js",
    "deploy-check": "NODE_ENV=production node scripts/deploy-check.js",
    "setup": "node setup.js",
    "test:cement-e2e": "node tests/cement-e2e-procurement-finance.test.js",
    "test:indent-grn-sin-e2e": "node tests/indent-grn-sin-finance-e2e.test.js",
    "test:full-indent-grn-sin-finance": "node tests/full-indent-inventory-grn-sin-finance-e2e.test.js",
    "test:advance-payment-e2e": "node tests/advance-payment-indent-grn-sin-finance-e2e.test.js",
    "test:procurement-finance-complete-e2e": "node tests/procurement-finance-complete-e2e.test.js",
    "test:grni-resolve-from-po": "node tests/grni-resolve-from-po-before-grn.test.js",
    "test:utility-bill-finance": "node tests/utility-bill-finance.test.js",
    "test:general-cash-approval-phase1": "node tests/general-cash-approval-phase1.test.js",
    "reset:utility-bill-finance": "node scripts/reset-utility-bill-finance-local.js",
    "test:procurement-vendor-billing-multi-grn": "node tests/procurement-vendor-billing-multi-grn-e2e.test.js",
    "clean:test-data": "node scripts/clean-procurement-finance-general-store-data.js --yes",
    "clean:finance-local": "node scripts/clean-finance-local-only.js --yes",
    "clean:admin-audit-local": "node scripts/clean-admin-audit-local-only.js --yes",
    "clean:monthly-payroll-dev": "node scripts/clean-monthly-payroll-dev-only.js",
    "seed:admin-utility-bill-local": "node scripts/seed-admin-utility-bill-local-only.js --yes",
    "seed:utility-2026": "node scripts/seed-centralized-store-utility-2026.js --yes",
    "seed:org-chart": "node scripts/seed-org-chart.js",
    "clean:finance-procurement:keep-masters": "node scripts/clean-finance-procurement-keep-masters.js --yes",
    "test:asset-tagging-e2e": "node tests/asset-tagging-e2e.test.js",
    "import:procurement-vendors": "node server/scripts/import-procurement-vendors-xlsx.js",
    "ensure:developer-user": "node server/scripts/ensure-developer-user.js",
    "ensure:developer-user:droplet": "bash scripts/ensure-developer-on-droplet.sh",
    "link:developer-employee": "node server/scripts/link-developer-employee.js",
    "list:employees-without-gross": "node server/scripts/list-active-employees-without-gross-salary.js",
    "mongo:show-target": "node scripts/show-mongodb-target.js",
    "mongo:show-target:prod": "NODE_ENV=production node scripts/show-mongodb-target.js",
    "mongo:show-target:prod:connect": "NODE_ENV=production node scripts/show-mongodb-target.js --connect",
    "fix:employee-ids:prod:dry-run": "NODE_ENV=production node server/scripts/fix-employee-ids-production.js --dry-run",
    "fix:employee-ids:prod": "NODE_ENV=production node server/scripts/fix-employee-ids-production.js",
    "extract:latha-map-shapes": "python3 scripts/extract-latha-map-shapes.py",
    "sync:taj-invoices-prod-to-local": "node scripts/sync-taj-property-invoices-prod-to-local.js",
    "demo:seed-full-advance-pending-finance": "node server/scripts/seed-full-advance-po-pending-finance.js",
    "demo:clear-full-advance": "node server/scripts/clear-full-advance-demo.js"
  },
  "keywords": [
    "erp",
    "enterprise",
    "hr",
    "finance",
    "procurement",
    "sales",
    "crm"
  ],
  "author": "ERP Team",
  "license": "MIT",
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.11.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "mongoose": "^7.5.0",
    "mongoose-paginate-v2": "^1.9.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.14.2",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "node-zklib": "^1.3.0",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.17.2",
    "puppeteer": "^24.15.0",
    "qrcode": "^1.5.4",
    "react-google-recaptcha": "^3.1.0",
    "redis": "^4.7.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "ws": "^8.18.3",
    "xlsx": "^0.18.5",
    "zklib-js-zkteko": "^1.3.4",
    "zkteco-js": "^1.7.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.1"
  }
}
